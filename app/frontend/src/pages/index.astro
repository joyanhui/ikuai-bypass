---
import '../styles/global.css';
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <title>iKuai Bypass</title>
  </head>
  <body class="bg-gradient-to-br from-gray-50 via-white to-gray-100 text-gray-900 transition-colors duration-500 dark:from-gray-950 dark:via-gray-900 dark:to-gray-950 dark:text-gray-100">
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -top-40 -right-40 h-80 w-80 rounded-full bg-gradient-to-br from-primary-400/20 to-accent-cyan/20 blur-3xl dark:from-primary-600/10 dark:to-accent-cyan/10"></div>
      <div class="absolute top-1/2 -left-20 h-60 w-60 rounded-full bg-gradient-to-br from-accent-purple/20 to-accent-rose/20 blur-3xl dark:from-accent-purple/10 dark:to-accent-rose/10"></div>
      <div class="absolute right-1/4 -bottom-20 h-72 w-72 rounded-full bg-gradient-to-br from-accent-emerald/20 to-accent-cyan/20 blur-3xl dark:from-accent-emerald/10 dark:to-accent-cyan/10"></div>
    </div>

    <header class="fixed top-0 left-0 right-0 z-40 border-b border-white/20 bg-white/70 backdrop-blur-xl transition-all duration-300 dark:border-gray-800/50 dark:bg-gray-950/70">
      <div class="mx-auto max-w-6xl px-4 py-3">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-gradient-to-br from-primary-500 to-accent-cyan shadow-lg shadow-primary-500/25">
              <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h1 class="bg-gradient-to-r from-gray-900 to-gray-600 bg-clip-text text-lg font-bold text-transparent dark:from-white dark:to-gray-400">iKuai Bypass</h1>
              <p class="text-xs text-gray-500 dark:text-gray-400" id="subtitle">智能分流管理</p>
            </div>
          </div>
          <button id="themeToggle" class="flex h-10 w-10 items-center justify-center rounded-xl bg-gray-100/80 text-gray-600 transition-all duration-200 active:scale-95 hover:bg-gray-200 dark:bg-gray-800/80 dark:text-gray-400 dark:hover:bg-gray-700">
            <svg class="hidden h-5 w-5 dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg class="block h-5 w-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <main class="relative z-10 mx-auto max-w-6xl px-4 pt-20 pb-24">
      <div class="mb-6">
        <div class="glass-card rounded-2xl p-2">
          <div class="grid grid-cols-3 gap-2" id="mainTabGrid">
            <button class="main-tab active" data-tab="runtime">运行模式</button>
            <button class="main-tab" data-tab="config">配置助手</button>
            <button class="main-tab" data-tab="cmd">命令生成器</button>
          </div>
        </div>
      </div>

      <section class="tab-panel" data-tab-panel="runtime">
        <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
          <div class="glass-card relative overflow-hidden rounded-3xl p-6">
            <div class="absolute top-0 right-0 -mt-10 -mr-10 h-32 w-32 rounded-full bg-gradient-to-br from-primary-500/10 to-accent-cyan/10 blur-2xl"></div>
            <div class="relative space-y-6">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <div class="text-sm font-medium text-gray-500 dark:text-gray-400">运行状态</div>
                  <div id="mainStatus" class="mt-1 text-3xl font-bold text-gray-900 dark:text-white">--</div>
                  <p id="subStatus" class="mt-1 text-sm text-gray-500 dark:text-gray-400">正在连接服务...</p>
                </div>
                <div class="flex flex-col items-end gap-3">
                  <span id="statusBadge" class="flex items-center gap-1.5 rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                    <span class="h-2 w-2 rounded-full bg-gray-400 animate-pulse"></span>
                    加载中...
                  </span>
                  <button id="btnRunAction" class="rounded-2xl bg-primary-600 px-5 py-3 text-sm font-bold text-white shadow-xl shadow-primary-600/30 transition-all active:scale-[0.98] hover:bg-primary-700">执行一次</button>
                </div>
              </div>

              <div class="space-y-3">
                <div class="flex items-center justify-between">
                  <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">运行模式</h2>
                </div>
                <div class="grid gap-2 sm:grid-cols-2 xl:grid-cols-4" id="runModeGrid">
                  <button class="run-mode-chip active" data-run-mode="once">
                    <span class="block text-sm font-semibold">once</span>
                    <span class="mt-1 block text-xs text-gray-500 dark:text-gray-400">执行一次</span>
                  </button>
                  <button class="run-mode-chip" data-run-mode="cron">
                    <span class="block text-sm font-semibold">cron</span>
                    <span class="mt-1 block text-xs text-gray-500 dark:text-gray-400">先执行后定时</span>
                  </button>
                  <button class="run-mode-chip" data-run-mode="cronAft">
                    <span class="block text-sm font-semibold">cronAft</span>
                    <span class="mt-1 block text-xs text-gray-500 dark:text-gray-400">直接定时</span>
                  </button>
                  <button class="run-mode-chip" data-run-mode="clean">
                    <span class="block text-sm font-semibold">clean</span>
                    <span class="mt-1 block text-xs text-gray-500 dark:text-gray-400">清理模式</span>
                  </button>
                </div>
              </div>

              <div class="space-y-3">
                <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">分流模块</h2>
                <div class="rounded-2xl border border-white/20 bg-white/20 p-2 dark:border-gray-800/60 dark:bg-gray-900/10">
                  <div class="grid grid-cols-3 gap-1" id="moduleGrid">
                    <button class="module-chip active" data-module="ispdomain"><span class="text-xs font-medium">运营商</span></button>
                    <button class="module-chip" data-module="ipgroup"><span class="text-xs font-medium">IP分组</span></button>
                    <button class="module-chip" data-module="ipv6group"><span class="text-xs font-medium">IPv6</span></button>
                    <button class="module-chip" data-module="ii"><span class="text-xs font-medium">混合</span></button>
                    <button class="module-chip" data-module="ip"><span class="text-xs font-medium">IP混合</span></button>
                    <button class="module-chip" data-module="iip"><span class="text-xs font-medium">全能</span></button>
                  </div>
                </div>
              </div>

              <div id="cronSection" class="hidden rounded-2xl border border-primary-500/15 bg-primary-500/5 p-4">
                <div class="flex items-center gap-3">
                  <span class="shrink-0 text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Cron</span>
                  <input id="cronInput" type="text" value="0 7 * * *" class="w-full bg-transparent py-1 text-sm text-gray-900 outline-none dark:text-white" placeholder="0 7 * * *" />
                </div>
              </div>

              <div id="cleanSection" class="hidden rounded-2xl border border-red-500/15 bg-red-500/5 p-4">
                <label class="mb-1 block text-xs text-gray-500 dark:text-gray-400">清理标签</label>
                <input id="cleanTagInput" type="text" class="w-full border-b border-gray-200 bg-transparent py-2 text-sm text-gray-900 outline-none transition-colors focus:border-red-500 dark:border-gray-700 dark:text-white" placeholder="请输入 tag 或 cleanAll" />
                <p class="mt-2 text-xs text-gray-400 dark:text-gray-500">安全要求：必须显式填写 tag 或 `cleanAll`。</p>
              </div>

            </div>
          </div>

          <div class="glass-card rounded-3xl p-5">
            <div class="mb-3 flex items-center justify-between px-1">
              <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">实时日志</h2>
              <button id="btnClearLogs" class="flex h-9 w-9 items-center justify-center rounded-xl bg-gray-100 text-gray-500 transition-colors hover:bg-gray-200 hover:text-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-gray-200" title="清空日志" aria-label="清空日志">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3M4 7h16" />
                </svg>
              </button>
            </div>
            <div class="relative overflow-hidden rounded-2xl bg-gray-950/90 p-4">
              <div id="logContainer" class="scrollbar-thin h-[28rem] space-y-1.5 overflow-y-auto font-mono text-xs text-gray-300">
                <div class="italic text-gray-500">等待日志输出...</div>
              </div>
              <div class="pointer-events-none absolute right-0 bottom-0 left-0 h-8 bg-gradient-to-t from-gray-950 to-transparent"></div>
            </div>
          </div>
        </div>
      </section>

      <section class="tab-panel hidden" data-tab-panel="config">
        <div class="space-y-6">
          <div class="glass-card rounded-3xl p-6">
            <div class="mb-6 flex items-center justify-between gap-3">
              <div>
                <h2 class="text-lg font-bold text-gray-900 dark:text-white">配置助手</h2>
              </div>
              <div class="text-sm text-gray-500 dark:text-gray-400" id="saveHint"></div>
            </div>
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div class="glass-card rounded-2xl p-1">
                <div class="grid grid-cols-2 gap-1" id="configSubTabGrid">
                  <button class="config-sub-tab active" data-config-tab="visual">可视化编辑</button>
                  <button class="config-sub-tab" data-config-tab="raw">文本编辑</button>
                </div>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <button id="btnOpenRemoteConfig" class="rounded-2xl bg-white px-4 py-2.5 text-sm font-medium text-gray-700 transition-all active:scale-95 hover:bg-gray-50 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">远程载入</button>
                <button id="btnSaveWithComments" class="rounded-2xl bg-gray-100 px-4 py-2.5 text-sm font-medium text-gray-700 transition-all active:scale-95 hover:bg-gray-200 dark:bg-gray-900 dark:text-gray-300 dark:hover:bg-gray-800">保存配置 (保留注释)</button>
                <button id="btnSaveNoComments" class="rounded-2xl bg-primary-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-primary-600/25 transition-all active:scale-95 hover:bg-primary-700">保存配置</button>
              </div>
            </div>
          </div>

          <div class="config-sub-panel" data-config-panel="visual">
            <div class="grid gap-6 xl:grid-cols-2">
              <div class="glass-card rounded-3xl p-6 xl:col-span-2">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-white">基本配置</h3>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">爱快连接、代理、WebUI、分页参数</p>
                  </div>
                  <button id="btnOpenBasicConfig" class="rounded-2xl bg-white px-4 py-2.5 text-sm font-medium text-gray-700 transition-all active:scale-95 hover:bg-gray-50 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">打开</button>
                </div>
              </div>
              <div class="glass-card rounded-3xl p-6">
                <div class="mb-4 flex items-center justify-between">
                  <h3 class="text-base font-semibold text-gray-900 dark:text-white">ISP / IP 分组 / IPv6 分组</h3>
                </div>
                <div class="space-y-4">
                  <div class="rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40">
                    <div class="mb-3 flex items-center justify-between">
                      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">自定义运营商</span>
                      <button id="addCustomIsp" class="rounded-full bg-primary-100 px-3 py-1 text-xs font-medium text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">添加</button>
                    </div>
                    <div id="listCustomIsp"></div>
                  </div>
                  <div class="rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40">
                    <div class="mb-3 flex items-center justify-between">
                      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">IPv4 分组</span>
                      <button id="addIpGroup" class="rounded-full bg-primary-100 px-3 py-1 text-xs font-medium text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">添加</button>
                    </div>
                    <div id="listIpGroup"></div>
                  </div>
                  <div class="rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40">
                    <div class="mb-3 flex items-center justify-between">
                      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">IPv6 分组</span>
                      <button id="addIpv6Group" class="rounded-full bg-primary-100 px-3 py-1 text-xs font-medium text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">添加</button>
                    </div>
                    <div id="listIpv6Group"></div>
                  </div>
                </div>
              </div>

              <div class="glass-card rounded-3xl p-6">
                <div class="mb-4 flex items-center justify-between">
                  <h3 class="text-base font-semibold text-gray-900 dark:text-white">流量分流规则</h3>
                </div>
                <div class="space-y-4">
                  <div class="rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40">
                    <div class="mb-3 flex items-center justify-between">
                      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">域名分流</span>
                      <button id="addStreamDomain" class="rounded-full bg-primary-100 px-3 py-1 text-xs font-medium text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">添加</button>
                    </div>
                    <div id="listStreamDomain"></div>
                  </div>
                  <div class="rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40">
                    <div class="mb-3 flex items-center justify-between">
                      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">IP / 端口分流</span>
                      <button id="addStreamIpPort" class="rounded-full bg-primary-100 px-3 py-1 text-xs font-medium text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">添加</button>
                    </div>
                    <div id="listStreamIpPort"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="config-sub-panel hidden" data-config-panel="raw">
            <div class="glass-card rounded-3xl p-6">
              <div class="mb-4 flex items-center justify-between">
                <h3 class="text-base font-semibold text-gray-900 dark:text-white">YAML 文本编辑</h3>
              </div>
              <div id="rawEditorContainer" class="min-h-[32rem] overflow-hidden rounded-3xl border border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-900"></div>
              <div class="mt-4 flex items-center justify-between gap-3">
                <div id="rawEditorHint" class="text-xs text-gray-500 dark:text-gray-400">切换回可视化编辑或点击顶部保存时会自动同步。</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="tab-panel hidden" data-tab-panel="cmd">
        <div class="glass-card rounded-3xl p-6">
          <div class="mb-6">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white">命令生成器</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400">保留 Go 版 WebUI 的核心命令构造能力，并适配当前风格。</p>
          </div>

          <div class="grid gap-6 xl:grid-cols-[0.8fr_1.2fr]">
            <div class="space-y-4">
              <div class="rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40">
                <div class="space-y-4">
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">运行模式</label>
                    <select id="cmdRunMode" class="w-full appearance-none rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white">
                      <option value="cron">cron (执行一次+定时)</option>
                      <option value="cronAft">cronAft (仅定时)</option>
                      <option value="once">once (执行一次退出)</option>
                      <option value="clean">clean (清理)</option>
                      <option value="web">web (仅WebUI)</option>
                    </select>
                  </div>
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">模块</label>
                    <select id="cmdModule" class="w-full appearance-none rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white">
                      <option value="ispdomain">ispdomain</option>
                      <option value="ipgroup">ipgroup</option>
                      <option value="ipv6group">ipv6group</option>
                      <option value="ii">ii</option>
                      <option value="ip">ip</option>
                      <option value="iip">iip</option>
                    </select>
                  </div>
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">配置路径</label>
                    <input id="cmdConfigPath" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" placeholder="./config.yml" />
                  </div>
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">清理标签</label>
                    <input id="cmdCleanTag" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" placeholder="cleanAll" />
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-700 dark:text-gray-300">随机后缀</span>
                    <div class="flex rounded-xl bg-white p-1 dark:bg-gray-800">
                      <button class="cmd-toggle rounded-lg px-4 py-1.5 text-sm font-medium transition-all" data-value="0">关闭</button>
                      <button class="cmd-toggle active rounded-lg px-4 py-1.5 text-sm font-medium transition-all" data-value="1">开启</button>
                    </div>
                  </div>
                </div>
              </div>

              <div>
                <div class="mb-3 flex items-center justify-between">
                  <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">命令预设</h3>
                  <button id="btnSavePreset" class="text-xs font-medium text-primary-600 dark:text-primary-400">保存当前</button>
                </div>
                <div id="presetList" class="space-y-2"></div>
              </div>
            </div>

            <div class="space-y-4">
              <div class="rounded-3xl bg-gray-950 p-5 shadow-2xl shadow-black/20">
                <div class="mb-3 flex items-center justify-between">
                  <span class="text-sm font-medium text-gray-300">生成的命令</span>
                  <button id="btnCopyCmd" class="text-xs font-medium text-primary-400">复制</button>
                </div>
                <code id="cmdOut" class="block min-h-32 whitespace-pre-wrap break-all font-mono text-xs text-gray-300"></code>
              </div>
              <div class="rounded-2xl border border-primary-500/15 bg-primary-500/5 p-4 text-sm text-gray-600 dark:text-gray-300">
                <div class="font-medium text-gray-900 dark:text-white">说明</div>
                <p class="mt-2">`clean`、`web` 等模式建议在命令行环境中使用。这里的命令生成器负责生成准确参数，便于直接复制执行。</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <div id="basicConfigModal" class="fixed inset-0 z-50 hidden">
      <div id="basicConfigBackdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity"></div>
      <div id="basicConfigContent" class="absolute inset-x-4 top-20 bottom-6 mx-auto max-w-5xl translate-y-6 overflow-hidden rounded-3xl bg-gray-50 shadow-2xl transition-transform dark:bg-gray-950">
        <div class="flex items-center justify-between border-b border-gray-200 px-6 py-4 dark:border-gray-800">
          <div>
            <h2 class="text-lg font-bold text-gray-900 dark:text-white">基本配置</h2>
          </div>
          <button id="btnCloseBasicConfig" class="rounded-2xl bg-primary-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary-700">确定</button>
        </div>

        <div class="h-full overflow-y-auto p-6 pb-28">
          <div class="grid gap-6 xl:grid-cols-2">
            <div class="space-y-6">
              <section class="space-y-3">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">iKuai 连接</h3>
                <div class="rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40">
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">路由器地址</label>
                    <input id="cfgIkuaiUrl" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" placeholder="http://192.168.9.1" />
                  </div>
                  <div class="mt-3 grid grid-cols-2 gap-3">
                    <div>
                      <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">用户名</label>
                      <input id="cfgUser" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" />
                    </div>
                    <div>
                      <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">密码</label>
                      <input id="cfgPass" type="password" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" />
                    </div>
                  </div>
                </div>
              </section>

              <section class="space-y-3">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">调度与代理</h3>
                <div class="grid gap-3 rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40 md:grid-cols-2">
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">GitHub 代理</label>
                    <input id="cfgGhProxy" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" placeholder="https://ghproxy.net/" />
                  </div>
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">错误重试等待</label>
                    <input id="cfgRetryWait" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" placeholder="10s" />
                  </div>
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">添加等待</label>
                    <input id="cfgAddWait" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" placeholder="1s" />
                  </div>
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">Cron</label>
                    <input id="cfgCronInline" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" placeholder="0 7 * * *" />
                  </div>
                </div>
              </section>
            </div>

            <div class="space-y-6">
              <section class="space-y-3">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">WebUI 设置</h3>
                <div class="rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40">
                  <div class="space-y-4">
                    <div class="flex items-center justify-between">
                      <span class="text-sm text-gray-700 dark:text-gray-300">启用 WebUI</span>
                      <label class="toggle-switch">
                        <input type="checkbox" id="cfgWebEnable" />
                        <span class="toggle-slider"></span>
                      </label>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                      <div>
                        <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">端口</label>
                        <input id="cfgWebPort" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" placeholder="19001" />
                      </div>
                      <div>
                        <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">CDN 前缀</label>
                        <input id="cfgWebCdn" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" placeholder="https://cdn.jsdelivr.net/npm" />
                      </div>
                      <div>
                        <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">用户名</label>
                        <input id="cfgWebUser" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" />
                      </div>
                      <div>
                        <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">密码</label>
                        <input id="cfgWebPass" type="password" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" />
                      </div>
                    </div>
                  </div>
                </div>
              </section>

              <section class="space-y-3">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">数据分页</h3>
                <div class="grid grid-cols-2 gap-3 rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40">
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">ISP 限制</label>
                    <input id="cfgMaxIsp" type="number" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" />
                  </div>
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">IPv4 限制</label>
                    <input id="cfgMaxIpv4" type="number" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" />
                  </div>
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">IPv6 限制</label>
                    <input id="cfgMaxIpv6" type="number" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" />
                  </div>
                  <div>
                    <label class="mb-1.5 block text-xs text-gray-500 dark:text-gray-400">Domain 限制</label>
                    <input id="cfgMaxDomain" type="number" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none dark:bg-gray-800 dark:text-white" />
                  </div>
                </div>
              </section>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="remoteConfigModal" class="fixed inset-0 z-50 hidden">
      <div id="remoteConfigBackdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity"></div>
      <div id="remoteConfigContent" class="absolute inset-x-4 top-28 mx-auto max-w-2xl translate-y-6 overflow-hidden rounded-3xl bg-gray-50 shadow-2xl transition-transform dark:bg-gray-950">
        <div class="flex items-center justify-between border-b border-gray-200 px-6 py-4 dark:border-gray-800">
          <div>
            <h2 class="text-lg font-bold text-gray-900 dark:text-white">远程载入</h2>
          </div>
          <button id="btnCloseRemoteConfig" class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-100 text-gray-600 transition hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="p-6">
          <div class="rounded-2xl bg-gray-100/60 p-4 dark:bg-gray-900/40">
            <input id="remoteUrl" type="text" class="w-full rounded-xl bg-white px-4 py-3 text-sm text-gray-900 outline-none ring-0 dark:bg-gray-800 dark:text-white" placeholder="https://raw.githubusercontent.com/.../config.yml" />
            <p class="mt-3 text-sm text-amber-600 dark:text-amber-400">使用远程配置覆盖本地配置。</p>
            <div class="mt-3 flex gap-2">
              <button id="btnLoadRemote" class="rounded-xl bg-primary-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-primary-700">加载</button>
              <button id="btnResetRemote" class="rounded-xl bg-white px-4 py-2.5 text-sm font-medium text-gray-700 transition hover:bg-gray-50 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">默认</button>
            </div>
            <p id="remoteHint" class="mt-2 text-xs text-gray-500"></p>
          </div>
        </div>
      </div>
    </div>

    <div id="ruleEditorModal" class="fixed inset-0 z-50 hidden">
      <div id="ruleEditorBackdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity"></div>
      <div id="ruleEditorContent" class="absolute inset-x-4 top-24 bottom-8 mx-auto max-w-4xl translate-y-6 overflow-hidden rounded-3xl bg-gray-50 shadow-2xl transition-transform dark:bg-gray-950">
        <div class="flex items-center justify-between border-b border-gray-200 px-6 py-4 dark:border-gray-800">
          <div>
            <h2 id="ruleEditorTitle" class="text-lg font-bold text-gray-900 dark:text-white">编辑规则</h2>
            <p id="ruleEditorSubtitle" class="text-sm text-gray-500 dark:text-gray-400">查看并修改当前规则内容。</p>
          </div>
          <button id="btnCloseRuleEditor" class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-100 text-gray-600 transition hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="h-full overflow-y-auto p-6 pb-28">
          <div id="ruleEditorForm" class="grid gap-4 md:grid-cols-2"></div>
        </div>
        <div class="absolute right-0 bottom-0 left-0 flex items-center justify-end gap-3 border-t border-gray-200 bg-white/90 px-6 py-4 backdrop-blur dark:border-gray-800 dark:bg-gray-950/90">
          <button id="btnDeleteRuleFromModal" class="mr-auto rounded-2xl bg-red-50 px-4 py-2.5 text-sm font-medium text-red-600 transition hover:bg-red-100 dark:bg-red-900/20 dark:text-red-400 dark:hover:bg-red-900/30">删除</button>
          <button id="btnCancelRuleEditor" class="rounded-2xl bg-white px-4 py-2.5 text-sm font-medium text-gray-700 transition hover:bg-gray-50 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">取消</button>
          <button id="btnSaveRuleEditor" class="rounded-2xl bg-primary-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-primary-600/25 transition hover:bg-primary-700">保存修改</button>
        </div>
      </div>
    </div>

    <div id="toast" class="pointer-events-none fixed bottom-24 left-1/2 z-50 -translate-x-1/2 translate-y-4 opacity-0 transition-all duration-300">
      <div class="rounded-full bg-gray-900 px-6 py-3 text-sm font-medium text-white shadow-xl dark:bg-white dark:text-gray-900">
        <span id="toastText">操作成功</span>
      </div>
    </div>

    <script src="../scripts/app.ts"></script>
  </body>
</html>
