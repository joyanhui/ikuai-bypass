#!/bin/sh

set -eu

# Why/为什么: LuCI IPK 只提供薄包装，实际安装/卸载/状态逻辑统一交给远程 install.sh。
# English: Keep the LuCI package small and delegate all lifecycle logic to install.sh.

INSTALL_URL="${IKB_INSTALL_URL:-https://joyanhui.github.io/ikuai-bypass/install.sh}"

fail() {
	printf 'status=error\n'
	printf 'message=%s\n' "$1"
	exit 1
}

export_proxy() {
	proxy="${IKB_PROXY:-}"
	[ -n "${proxy}" ] || return 0
	case "${proxy}" in
		http://*|https://*) ;;
		*) fail "Proxy must start with http:// or https://" ;;
	esac
	export http_proxy="${proxy}"
	export https_proxy="${proxy}"
	export HTTP_PROXY="${proxy}"
	export HTTPS_PROXY="${proxy}"
}

run_install_sh() {
	export_proxy
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "${INSTALL_URL}" | sh -s -- "$@"
	elif command -v wget >/dev/null 2>&1; then
		wget -qO- "${INSTALL_URL}" | sh -s -- "$@"
	else
		fail "curl or wget is required"
	fi
}

case "${1:-status}" in
	inspect)
		shift
		run_install_sh status "$@"
		;;
	status|install|update|uninstall|start|stop|restart|enable|disable|log)
		action="$1"
		shift
		run_install_sh "${action}" "$@"
		;;
	*)
		fail "Unsupported action. Supported: status, inspect, install, update, uninstall, start, stop, restart, enable, disable, log"
		;;
esac
