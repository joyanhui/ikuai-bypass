#!/bin/sh

set -eu

# Why/为什么: LuCI IPK 只提供薄包装，实际安装/卸载/状态逻辑统一交给 install.sh。
# English: Keep the LuCI package small and cache install.sh in /tmp to avoid refetching it for every button click.

INSTALL_URL="${IKB_INSTALL_URL:-https://joyanhui.github.io/ikuai-bypass/install.sh}"
BASE_URL="${INSTALL_URL%/install.sh}"
CACHE_DIR="/tmp/ikuai-bypass-install-cache"
CACHE_INSTALL_SH="${CACHE_DIR}/install.sh"
CACHE_COMMON_DIR="${CACHE_DIR}/install-file"
CACHE_COMMON_SH="${CACHE_COMMON_DIR}/common.sh"
CACHE_STAMP="${CACHE_DIR}/.stamp"
CACHE_TTL="${IKB_INSTALL_CACHE_TTL:-21600}"

fail() {
	printf 'status=error\n'
	printf 'message=%s\n' "$1"
	exit 1
}

export_proxy() {
	proxy="${IKB_PROXY:-}"
	[ -n "${proxy}" ] || return 0
	case "${proxy}" in
		http://*|https://*) ;;
		*) fail "Proxy must start with http:// or https://" ;;
	esac
	export http_proxy="${proxy}"
	export https_proxy="${proxy}"
	export HTTP_PROXY="${proxy}"
	export HTTPS_PROXY="${proxy}"
}

now_ts() {
	date +%s 2>/dev/null || printf '0'
}

cache_fresh() {
	[ -f "${CACHE_INSTALL_SH}" ] || return 1
	[ -f "${CACHE_COMMON_SH}" ] || return 1
	[ -f "${CACHE_STAMP}" ] || return 1
	now="$(now_ts)"
	stamp="$(cat "${CACHE_STAMP}" 2>/dev/null || printf '0')"
	[ $((now - stamp)) -lt "${CACHE_TTL}" ] 2>/dev/null
}

download_file() {
	url="$1"
	dst="$2"
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL --connect-timeout 10 --max-time 60 -o "${dst}" "${url}"
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "${dst}" "${url}" --timeout=60
	else
		fail "curl or wget is required"
	fi
}

refresh_cache() {
	export_proxy
	tmp_dir="$(mktemp -d 2>/dev/null || mktemp -d -t ikb-install-cache)"
	mkdir -p "${tmp_dir}/install-file" "${CACHE_COMMON_DIR}"
	download_file "${INSTALL_URL}" "${tmp_dir}/install.sh"
	download_file "${BASE_URL}/install-file/common.sh" "${tmp_dir}/install-file/common.sh"
	sh -n "${tmp_dir}/install.sh" || fail "Downloaded install.sh has invalid syntax"
	sh -n "${tmp_dir}/install-file/common.sh" || fail "Downloaded common.sh has invalid syntax"
	mkdir -p "${CACHE_COMMON_DIR}"
	cp "${tmp_dir}/install.sh" "${CACHE_INSTALL_SH}"
	cp "${tmp_dir}/install-file/common.sh" "${CACHE_COMMON_SH}"
	now_ts > "${CACHE_STAMP}"
	rm -rf "${tmp_dir}"
}

ensure_cache() {
	force="${1:-0}"
	if [ "${force}" = "1" ] || ! cache_fresh; then
		if ! refresh_cache; then
			[ -f "${CACHE_INSTALL_SH}" ] && [ -f "${CACHE_COMMON_SH}" ] || fail "Failed to download install.sh cache"
		fi
	fi
}

run_install_sh() {
	ensure_cache 0
	export_proxy
	sh "${CACHE_INSTALL_SH}" "$@"
}

case "${1:-status}" in
	inspect)
		shift
		run_install_sh status "$@"
		;;
	luci-version)
		ctrl="/usr/lib/opkg/info/luci-app-ikuai-bypass.control"
		if [ -f "$ctrl" ]; then
			ver="$(grep '^Version:' "$ctrl" | sed 's/^Version: *//')"
			printf 'version=%s\n' "${ver}"
		else
			fail "Control file not found"
		fi
		;;
	luci-check)
		printf '[IKB] 1/3 正在配置网络代理...\n'
		export_proxy
		printf '[IKB] 2/3 正在请求 GitHub API...\n'
		url="https://github.com/joyanhui/ikuai-bypass/releases/latest/download/ikuai-bypass-luci-openwrt-all.ipk"
		effective="$(curl -fsSL -o /dev/null -w '%{url_effective}' "${url}" --connect-timeout 10 --max-time 30)" || fail "Failed to check latest version"
		printf '[IKB] 3/3 正在解析最新版本...\n'
		latest_ver="$(echo "${effective}" | sed -n 's|.*/download/\([^/]*\)/.*|\1|p')"
		[ -n "${latest_ver}" ] || fail "Could not extract version from redirect"
		printf 'latest_version=%s\n' "${latest_ver}"
		;;
	luci-update)
		printf '[IKB] 1/4 正在配置网络代理...\n'
		export_proxy
		printf '[IKB] 2/4 正在下载最新插件包...\n'
		tmp="/tmp/luci-ikuai-bypass-update.ipk"
		url="https://github.com/joyanhui/ikuai-bypass/releases/latest/download/ikuai-bypass-luci-openwrt-all.ipk"
		download_file "${url}" "${tmp}" || fail "Download failed"
		printf '[IKB] 3/4 正在安装插件...\n'
		opkg install "${tmp}" --force-overwrite 2>&1 || { rm -f "${tmp}"; fail "Install failed"; }
		printf '[IKB] 4/4 正在清理临时文件...\n'
		rm -f "${tmp}"
		printf 'status=ok\nmessage=Plugin updated successfully\n'
		;;
	latest)
		printf '[IKB] 1/3 正在获取安装脚本...\n'
		ensure_cache 0
		export_proxy
		printf '[IKB] 2/3 正在请求 GitHub API...\n'
		run_install_sh latest
		printf '[IKB] 3/3 解析完成\n'
		;;
	install)
		printf '[IKB] 1/5 正在获取安装脚本...\n'
		ensure_cache 0
		export_proxy
		printf '[IKB] 2/5 正在检测系统信息...\n'
		run_install_sh install
		printf '[IKB] 5/5 正在配置服务...\n'
		;;
	status|update|uninstall|start|stop|restart|enable|disable|log)
		action="$1"
		shift
		run_install_sh "${action}" "$@"
		;;
	refresh-cache)
		refresh_cache
		printf 'status=ok\nmessage=install.sh cache refreshed\n'
		;;
	*)
		fail "Unsupported action. Supported: status, inspect, latest, install, update, uninstall, start, stop, restart, enable, disable, log, refresh-cache, luci-version, luci-check, luci-update"
		;;
esac
