---
import appUrl from '../scripts/app.ts?url';
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>iKuai Bypass</title>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
      @theme {
        --color-primary-50: var(--color-blue-50);
        --color-primary-500: var(--color-blue-500);
        --color-primary-600: var(--color-blue-600);
        --color-primary-700: var(--color-blue-700);
      }
      @custom-variant dark (&:where(.dark, .dark *));
      [x-cloak] { display: none !important; }
    </style>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-300 min-h-screen font-sans">
    <!-- Header -->
    <header class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 transition-colors duration-300 shadow-sm">
      <div class="max-w-[1400px] mx-auto px-4 py-4">
        <div class="flex flex-wrap justify-between items-center gap-3">
          <div class="flex flex-col">
            <b class="text-lg font-semibold tracking-tight">iKuai Bypass</b>
            <span class="text-xs text-gray-500 dark:text-gray-400" id="subtitle">WebUI</span>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <span class="px-3 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300" id="envBadge">env=web</span>
            <span class="px-3 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300" id="confBadge">conf=</span>
            <span class="px-3 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300" id="themeBadge">theme=auto</span>
            <button id="themeLight" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/30 hover:border-blue-300 dark:hover:border-blue-600 transition-all">浅色</button>
            <button id="themeDark" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/30 hover:border-blue-300 dark:hover:border-blue-600 transition-all">深色</button>
            <button id="themeAuto" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/30 hover:border-blue-300 dark:hover:border-blue-600 transition-all">自动</button>
          </div>
        </div>

        <!-- Tabs -->
        <div class="flex gap-2 mt-3.5 overflow-x-auto -webkit-overflow-scrolling-touch" id="tabs">
          <button class="tab-btn" data-tab="help">使用说明</button>
          <button class="tab-btn" data-tab="config">配置助手</button>
          <button class="tab-btn" data-tab="cmd">命令生成器</button>
          <button class="tab-btn" data-tab="runtime">运行与日志</button>
        </div>
      </div>
    </header>

    <main class="max-w-[1400px] mx-auto p-6">
      <!-- Help Page -->
      <section class="panel" id="pageHelp" style="display:none">
        <div class="flex flex-wrap justify-between items-center mb-5">
          <span class="text-lg font-semibold tracking-tight">配置助手</span>
          <span class="text-sm text-gray-500 dark:text-gray-400" id="configHint"></span>
        </div>
        <div class="h-px bg-gray-200 dark:bg-gray-700 my-6"></div>
        <div class="text-sm text-gray-500 dark:text-gray-400">
          <div class="mb-3"><b>1)</b> 在「配置助手」中填写 iKuai 登录信息、订阅 URL、Cron 等。</div>
          <div class="mb-3"><b>2)</b> 保存配置（需要 webui.enable-update=true）。</div>
          <div><b>3)</b> 在「运行与日志」执行一次或启动定时任务。</div>
        </div>
      </section>

      <!-- Config Page -->
      <section class="panel" id="pageConfig" style="display:none">
        <div class="flex flex-wrap justify-between items-center mb-5">
          <span class="text-lg font-semibold tracking-tight">配置助手</span>
          <span class="text-sm text-gray-500 dark:text-gray-400" id="configHint"></span>
        </div>
        
        <!-- Save bar -->
        <div class="flex flex-wrap items-center gap-3 p-5 bg-white/50 dark:bg-gray-800/50 backdrop-blur-sm border border-gray-200 dark:border-gray-700 rounded-xl mb-6 shadow-sm">
          <button id="btnSaveNoComments" class="px-4 py-2.5 text-sm font-medium rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition-all border border-transparent">保存配置</button>
          <button id="btnSaveWithComments" class="px-4 py-2.5 text-sm font-medium rounded-lg bg-gray-100 dark:bg-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/30 text-gray-700 dark:text-gray-300 transition-all border border-gray-200 dark:border-gray-600">保存(带注释)</button>
          <span class="text-sm text-gray-500 dark:text-gray-400 flex-1 text-right" id="saveHint"></span>
        </div>
        
        <!-- Edit mode tabs -->
        <div class="flex gap-2 mb-6 border-b-2 border-gray-200 dark:border-gray-700 pb-0" id="editTabs">
          <button class="edit-tab active" data-edit="visual">可视化编辑</button>
          <button class="edit-tab" data-edit="manual">手动编辑</button>
        </div>
        
        <!-- Visual Edit Mode -->
        <div id="visualEditContainer">
          <!-- Sub-tabs -->
          <div class="flex flex-wrap gap-2 mb-6 border-b border-gray-200 dark:border-gray-700 pb-3" id="configSubTabs">
            <button class="sub-tab active" data-subtab="basic">基础</button>
            <button class="sub-tab" data-subtab="limits">数据分页</button>
            <button class="sub-tab" data-subtab="rules">规则</button>
          </div>

          <!-- Basic Section (includes remote + webui) -->
          <div class="config-section active" id="sectionBasic">
            <!-- Remote Config - FIRST -->
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">远程配置加载</div>
              <div class="text-sm text-gray-500 dark:text-gray-400 mb-4">支持 raw.githubusercontent.com + github-proxy</div>
              <div class="flex flex-col gap-3">
                <input id="remoteUrl" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" placeholder="https://raw.githubusercontent.com/.../config.yml" />
                <div class="flex flex-wrap gap-3">
                  <button id="btnLoadRemote" class="px-4 py-2.5 text-sm font-medium rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition-all border border-transparent">加载并覆盖</button>
                  <button id="btnResetRemote" class="px-4 py-2.5 text-sm font-medium rounded-lg bg-gray-100 dark:bg-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/30 text-gray-700 dark:text-gray-300 transition-all border border-gray-200 dark:border-gray-600">恢复默认</button>
                </div>
              </div>
              <div class="text-sm text-gray-500 dark:text-gray-400 mt-3" id="remoteHint"></div>
            </div>

            <div class="h-px bg-gray-200 dark:bg-gray-700 my-6"></div>

            <!-- iKuai Connection -->
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">iKuai 连接</div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">ikuai-url</label>
                  <input id="cfgIkuaiUrl" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" placeholder="http://192.168.9.1" />
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">username</label>
                  <input id="cfgUser" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" />
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">password</label>
                  <input id="cfgPass" type="password" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" />
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">cron</label>
                  <input id="cfgCron" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" placeholder="0 7 * * *" />
                </div>
              </div>
            </div>
            
            <!-- Proxy -->
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">代理</div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">github-proxy</label>
                  <input id="cfgGhProxy" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" placeholder="https://ghproxy.net/" />
                </div>
              </div>
            </div>
            
            <!-- Timing Parameters -->
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">Timing 参数</div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">AddErrRetryWait</label>
                  <input id="cfgRetryWait" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" placeholder="10s" />
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">AddWait</label>
                  <input id="cfgAddWait" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" placeholder="1s" />
                </div>
              </div>
            </div>

            <!-- WebUI Settings - MOVED INTO BASIC -->
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">WebUI 设置</div>
              <div class="text-sm text-gray-500 dark:text-gray-400 mb-4">保存功能受 webui.enable-update 控制</div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">enable</label>
                  <label class="toggle-switch">
                    <input type="checkbox" id="cfgWebEnable" />
                    <span class="toggle-slider"></span>
                  </label>
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">enable-update</label>
                  <label class="toggle-switch">
                    <input type="checkbox" id="cfgWebEnableUpdate" />
                    <span class="toggle-slider"></span>
                  </label>
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">port</label>
                  <input id="cfgWebPort" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" placeholder="19001" />
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">cdn-prefix</label>
                  <input id="cfgWebCdn" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" placeholder="https://cdn.jsdelivr.net/npm" />
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">user</label>
                  <input id="cfgWebUser" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" />
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">pass</label>
                  <input id="cfgWebPass" type="password" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" />
                </div>
              </div>
            </div>
          </div>

          <!-- Data Pagination Section (renamed from Limits) -->
          <div class="config-section" id="sectionDataPagination">
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">单条数据长度</div>
              <div class="text-sm text-gray-500 dark:text-gray-400 mb-4">单条数据长度，需要根据路由器性能和数据情况调整。(参考值：ISP: 3000, IPv4: 1000, IPv6: 1000, Domain: 1000)</div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">Isp</label>
                  <input id="cfgMaxIsp" type="number" min="1" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" />
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">Ipv4</label>
                  <input id="cfgMaxIpv4" type="number" min="1" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" />
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">Ipv6</label>
                  <input id="cfgMaxIpv6" type="number" min="1" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" />
                </div>
                <div>
                  <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1.5 font-medium">Domain</label>
                  <input id="cfgMaxDomain" type="number" min="1" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" />
                </div>
              </div>
            </div>
          </div>

          <!-- Rules Section -->
          <div class="config-section" id="sectionRules">
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">custom-isp</div>
              <div class="flex flex-wrap justify-between items-center gap-3 mb-3">
                <span class="text-sm text-gray-500 dark:text-gray-400">自定义运营商规则</span>
                <button id="addCustomIsp" class="px-4 py-2 text-sm font-medium rounded-lg bg-gray-100 dark:bg-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/30 text-gray-700 dark:text-gray-300 transition-all border border-gray-200 dark:border-gray-600">新增</button>
              </div>
              <div class="flex flex-col gap-4" id="listCustomIsp"></div>
            </div>
            
            <div class="h-px bg-gray-200 dark:bg-gray-700 my-6"></div>
            
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">ip-group</div>
              <div class="flex flex-wrap justify-between items-center gap-3 mb-3">
                <span class="text-sm text-gray-500 dark:text-gray-400">IP 分组规则</span>
                <button id="addIpGroup" class="px-4 py-2 text-sm font-medium rounded-lg bg-gray-100 dark:bg-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/30 text-gray-700 dark:text-gray-300 transition-all border border-gray-200 dark:border-gray-600">新增</button>
              </div>
              <div class="flex flex-col gap-4" id="listIpGroup"></div>
            </div>
            
            <div class="h-px bg-gray-200 dark:bg-gray-700 my-6"></div>
            
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">ipv6-group</div>
              <div class="flex flex-wrap justify-between items-center gap-3 mb-3">
                <span class="text-sm text-gray-500 dark:text-gray-400">IPv6 分组规则</span>
                <button id="addIpv6Group" class="px-4 py-2 text-sm font-medium rounded-lg bg-gray-100 dark:bg-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/30 text-gray-700 dark:text-gray-300 transition-all border border-gray-200 dark:border-gray-600">新增</button>
              </div>
              <div class="flex flex-col gap-4" id="listIpv6Group"></div>
            </div>
            
            <div class="h-px bg-gray-200 dark:bg-gray-700 my-6"></div>
            
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">stream-domain</div>
              <div class="flex flex-wrap justify-between items-center gap-3 mb-3">
                <span class="text-sm text-gray-500 dark:text-gray-400">域名分流规则</span>
                <button id="addStreamDomain" class="px-4 py-2 text-sm font-medium rounded-lg bg-gray-100 dark:bg-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/30 text-gray-700 dark:text-gray-300 transition-all border border-gray-200 dark:border-gray-600">新增</button>
              </div>
              <div class="flex flex-col gap-4" id="listStreamDomain"></div>
            </div>
            
            <div class="h-px bg-gray-200 dark:bg-gray-700 my-6"></div>
            
            <div class="mb-7">
              <div class="text-base font-semibold text-gray-900 dark:text-gray-400 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">stream-ipport</div>
              <div class="flex flex-wrap justify-between items-center gap-3 mb-3">
                <span class="text-sm text-gray-500 dark:text-gray-400">端口分流规则</span>
                <button id="addStreamIpPort" class="px-4 py-2 text-sm font-medium rounded-lg bg-gray-100 dark:bg-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/30 text-gray-700 dark:text-gray-300 transition-all border border-gray-200 dark:border-gray-600">新增</button>
              </div>
              <div class="flex flex-col gap-4" id="listStreamIpPort"></div>
            </div>
          </div>
        </div>

        <!-- Manual Edit Mode (Monaco) -->
        <div id="manualEditContainer" style="display: none;">
          <!-- Remote Config - ALSO in Manual Edit -->
          <div class="mb-7">
            <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">远程配置加载</div>
            <div class="text-sm text-gray-500 dark:text-gray-400 mb-4">支持 raw.githubusercontent.com + github-proxy</div>
            <div class="flex flex-col gap-3">
              <input id="remoteUrlManual" class="w-full px-3.5 py-3 text-sm rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all min-h-[44px]" placeholder="https://raw.githubusercontent.com/.../config.yml" />
              <div class="flex flex-wrap gap-3">
                <button id="btnLoadRemoteManual" class="px-4 py-2.5 text-sm font-medium rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition-all border border-transparent">加载并覆盖</button>
                <button id="btnResetRemoteManual" class="px-4 py-2.5 text-sm font-medium rounded-lg bg-gray-100 dark:bg-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/30 text-gray-700 dark:text-gray-300 transition-all border border-gray-200 dark:border-gray-600">恢复默认</button>
              </div>
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400 mt-3" id="remoteHintManual"></div>
          </div>

          <div class="h-px bg-gray-200 dark:bg-gray-700 my-6"></div>
          
          <div class="mb-7">
            <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4 pb-2.5 border-b border-gray-200 dark:border-gray-700 tracking-tight">YAML 手动编辑</div>
