    <style>
      /* Tab button styles */
      .tab-btn {
        border: 1px solid rgb(203 213 225 / 0.6);
        background: rgb(241 245 249 / 0.8);
        color: rgb(30 41 59);
        padding: 10px 18px;
        border-radius: 10px;
        cursor: pointer;
        font-size: 13px;
        white-space: nowrap;
        min-height: 40px;
        transition: all 0.2s ease;
      }
      :global(.dark) .tab-btn {
        background: rgb(51 65 85 / 0.6);
        color: rgb(241 245 249);
        border-color: rgb(148 163 184 / 0.1);
      }
      .tab-btn:hover {
        background: rgb(59 130 246 / 0.1);
        border-color: rgb(59 130 246 / 0.5);
        transform: translateY(-1px);
      }
      .tab-btn.active {
        background: rgb(59 130 246 / 0.15);
        border-color: rgb(59 130 246 / 0.5);
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      }

      /* Panel/Card styles */
      .panel {
        border: 1px solid rgb(203 213 225 / 0.6);
